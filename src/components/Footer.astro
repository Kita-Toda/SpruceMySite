<style>
.foot-links{display:flex;flex-wrap:wrap;gap:8px 20px;align-items:center}
.foot-links a{color:rgba(251,244,231,.65);font-size:.88rem;font-weight:600;text-decoration:none;transition:color .25s}
.foot-links a:hover{color:var(--cream)}
.copyright a{color:rgba(251,244,231,.65);text-decoration:none;transition:color .25s}
.copyright a:hover{color:var(--cream)}
