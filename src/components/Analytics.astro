        <div class="cat">
          <span class="ick"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M8 17v-5M13 17V8M18 17v-9"/></svg></span>
          <div><span class="n">01</span><h3>Core Web Analytics</h3></div>
        </div>
