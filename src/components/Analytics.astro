          <div class="top">
            <a class="name" href="https://marketingplatform.google.com/about/analytics/" target="_blank" rel="noopener" data-cursor>Google Analytics 4 <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M8 7h9v9"/></svg></a>
