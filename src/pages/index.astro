---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Stats from '../components/Stats.astro';
import About from '../components/About.astro';
import LeadEngine from '../components/LeadEngine.astro';
import Services from '../components/Services.astro';
import Analytics from '../components/Analytics.astro';
import KeysBand from '../components/KeysBand.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import Quote from '../components/Quote.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Fragment slot="head">
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" integrity="sha512-dLxUelApnYxpLt6K2iomGngnHO83iUvZytA3YjDUCjT0HDOHKXnVYdf3hU4JjM8uEhxf9nD1/ey98U3t2vZ0qQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  </Fragment>
  <Nav />
  <Hero />
  <Marquee />
  <Stats />
  <About />
  <LeadEngine />
  <Services />
  <Analytics />
  <KeysBand />
  <Reviews />
  <FAQ />
  <Quote />
  <Contact />
  <Footer />
</Layout>

<script>
const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

/* ---------- footer year ---------- */
const yr = document.getElementById('yr');
if (yr) yr.textContent = String(new Date().getFullYear());

/* ---------- custom cursor ---------- */
(function(){
  const c = document.querySelector('.cursor') as HTMLElement | null;
  const d = document.querySelector('.cursor-dot') as HTMLElement | null;
  if (!c || !d) return;
  let x = innerWidth/2, y = innerHeight/2, cx = x, cy = y;
  addEventListener('mousemove', e => {
    x = e.clientX; y = e.clientY;
    d.style.transform = `translate(${x}px,${y}px) translate(-50%,-50%)`;
  });
  (function loop(){
    cx += (x - cx) * 0.18; cy += (y - cy) * 0.18;
    c.style.transform = `translate(${cx}px,${cy}px) translate(-50%,-50%)`;
    requestAnimationFrame(loop);
  })();
  const grow = () => c.classList.add('grow');
  const shr  = () => c.classList.remove('grow');
  document.querySelectorAll('[data-cursor],a,button').forEach(el => {
    el.addEventListener('mouseenter', grow);
    el.addEventListener('mouseleave', shr);
  });
})();

/* ---------- header scroll shadow ---------- */
const header = document.getElementById('header') as HTMLElement | null;
addEventListener('scroll', () => header?.classList.toggle('scrolled', scrollY > 40));

/* ---------- burger menu ---------- */
const burger = document.getElementById('burger') as HTMLButtonElement | null;
const menu   = document.getElementById('menu')   as HTMLElement | null;
burger?.addEventListener('click', () => {
  const open = menu?.classList.toggle('open');
  burger.setAttribute('aria-expanded', String(open));
});
menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  menu.classList.remove('open');
  burger?.setAttribute('aria-expanded', 'false');
}));

/* ---------- THREE.JS — sage coffee mug with rising steam ---------- */
(function(){
  const THREE = (window as any).THREE;
  if (!THREE) return;
  const stage = document.getElementById('stage'); if (!stage) return;
  const size = () => Math.min(stage.clientWidth, stage.clientHeight);
  const scene = new THREE.Scene();
  const cam = new THREE.PerspectiveCamera(40, 1, 0.1, 100); cam.position.set(0, 1.1, 7.4);
  const r = new THREE.WebGLRenderer({alpha: true, antialias: true});
  r.setPixelRatio(Math.min(devicePixelRatio, 2)); r.setSize(size(), size());
  stage.appendChild(r.domElement);

  scene.add(new THREE.AmbientLight(0xfff1dc, 0.85));
  const key = new THREE.DirectionalLight(0xffd9a0, 1.5); key.position.set(4, 6, 5); scene.add(key);
  const rim = new THREE.DirectionalLight(0xd9582f, 0.7); rim.position.set(-5, 2, -3); scene.add(rim);

  const group = new THREE.Group(); scene.add(group);
  const ceramic   = new THREE.MeshStandardMaterial({color:0x7C4DE0, roughness:0.35, metalness:0.05});
  const ceramicIn = new THREE.MeshStandardMaterial({color:0x5B37A8, roughness:0.5, side:THREE.DoubleSide});
  const coffee    = new THREE.MeshStandardMaterial({color:0x2a1a0f, roughness:0.2, metalness:0.1});
  const cream     = new THREE.MeshStandardMaterial({color:0xf6ecd8, roughness:0.6});

  const body   = new THREE.Mesh(new THREE.CylinderGeometry(1.15,0.95,1.7,48,1,true), ceramic); group.add(body);
  const inner  = new THREE.Mesh(new THREE.CylinderGeometry(1.05,0.86,1.66,48,1,true), ceramicIn); group.add(inner);
  const bottom = new THREE.Mesh(new THREE.CircleGeometry(0.95,48), ceramic);
  bottom.rotation.x = -Math.PI/2; bottom.position.y = -0.85; group.add(bottom);
  const surf = new THREE.Mesh(new THREE.CircleGeometry(1.03,48), coffee);
  surf.rotation.x = -Math.PI/2; surf.position.y = 0.74; group.add(surf);
  const rimR = new THREE.Mesh(new THREE.TorusGeometry(1.13,0.07,16,60), ceramic);
  rimR.rotation.x = Math.PI/2; rimR.position.y = 0.85; group.add(rimR);
  const handle = new THREE.Mesh(new THREE.TorusGeometry(0.5,0.13,16,40,Math.PI*1.35), ceramic);
  handle.position.set(1.15,0,0); handle.rotation.z = -0.35; group.add(handle);
  const saucer = new THREE.Mesh(new THREE.CylinderGeometry(1.85,1.7,0.12,48), cream);
  saucer.position.y = -1.0; group.add(saucer);

  const steamTex = (()=>{
    const cv = document.createElement('canvas'); cv.width = cv.height = 64;
    const g = cv.getContext('2d')!;
    const gr = g.createRadialGradient(32,32,0,32,32,32);
    gr.addColorStop(0,'rgba(255,255,255,.9)'); gr.addColorStop(1,'rgba(255,255,255,0)');
    g.fillStyle = gr; g.fillRect(0,0,64,64);
    return new THREE.CanvasTexture(cv);
  })();
  const N = 46, pos = new Float32Array(N*3), seed: {a:number,rad:number,sp:number,ph:number}[] = [];
  for (let i = 0; i < N; i++) {
    const a = Math.random()*Math.PI*2, rad = Math.random()*0.7;
    pos[i*3] = Math.cos(a)*rad; pos[i*3+1] = 0.8+Math.random()*2.4; pos[i*3+2] = Math.sin(a)*rad;
    seed.push({a, rad, sp: 0.004+Math.random()*0.008, ph: Math.random()*10});
  }
  const sg = new THREE.BufferGeometry(); sg.setAttribute('position', new THREE.BufferAttribute(pos,3));
  const sm = new THREE.PointsMaterial({map:steamTex,color:0xffffff,size:0.5,transparent:true,opacity:0.34,depthWrite:false,blending:THREE.AdditiveBlending,sizeAttenuation:true});
  const steam = new THREE.Points(sg, sm); group.add(steam);

  group.rotation.x = 0.12;
  let mx = 0, my = 0, tx = 0, ty = 0;
  addEventListener('mousemove', e => { tx = (e.clientX/innerWidth-0.5); ty = (e.clientY/innerHeight-0.5); });

  let userYaw = 0, userPitch = 0, velYaw = 0, dragging = false, lastX = 0, lastY = 0;
  const cnv = r.domElement; cnv.style.cursor = 'grab'; cnv.style.touchAction = 'none';
  const hint = document.getElementById('spinhint');
  const hideHint = () => hint?.classList.add('hide');
  setTimeout(hideHint, 7000);
  const gx = (e: MouseEvent | TouchEvent) => 'touches' in e ? e.touches[0].clientX : e.clientX;
  const gy = (e: MouseEvent | TouchEvent) => 'touches' in e ? e.touches[0].clientY : e.clientY;
  function down(e: MouseEvent | TouchEvent){ dragging=true; velYaw=0; lastX=gx(e); lastY=gy(e); cnv.style.cursor='grabbing'; hideHint(); }
  function move(e: MouseEvent | TouchEvent){
    if (!dragging) return;
    const x=gx(e), y=gy(e), dx=x-lastX, dy=y-lastY; lastX=x; lastY=y;
    userYaw += dx*0.01; userPitch = Math.max(-0.8, Math.min(0.8, userPitch+dy*0.01)); velYaw = dx*0.01;
    if ((e as TouchEvent).cancelable) e.preventDefault();
  }
  function up(){ if(dragging){ dragging=false; cnv.style.cursor='grab'; } }
  cnv.addEventListener('mousedown', down as EventListener);
  cnv.addEventListener('touchstart', down as EventListener, {passive:false});
  addEventListener('mousemove', move as EventListener, {passive:false});
  addEventListener('touchmove', move as EventListener, {passive:false});
  addEventListener('mouseup', up); addEventListener('touchend', up);

  let t = 0;
  function anim(){
    requestAnimationFrame(anim); t += 0.01;
    const p = steam.geometry.attributes.position.array as Float32Array;
    for (let i = 0; i < N; i++){
      p[i*3+1] += seed[i].sp;
      p[i*3] = Math.cos(seed[i].a+t*0.6+seed[i].ph)*seed[i].rad*(1+(p[i*3+1]-0.8)*0.25);
      if (p[i*3+1] > 3.4) p[i*3+1] = 0.8;
    }
    steam.geometry.attributes.position.needsUpdate = true;
    mx += (tx-mx)*0.05; my += (ty-my)*0.05;
    if (!dragging){ userYaw += velYaw; velYaw *= 0.94; }
    const rock = Math.sin(t*0.4)*0.12;
    group.rotation.y = rock + userYaw + mx*0.4;
    group.rotation.x = 0.12 + userPitch + my*0.15;
    group.position.y = Math.sin(t)*0.06;
    r.render(scene, cam);
  }
  anim();
  addEventListener('resize', () => { r.setSize(size(), size()); });
})();

/* ---------- GSAP scroll animations ---------- */
const gsap = (window as any).gsap;
const ScrollTrigger = (window as any).ScrollTrigger;
if (gsap && ScrollTrigger) {
  gsap.registerPlugin(ScrollTrigger);

  if (!reduced) {
    gsap.from('.hero-copy > *', {y:40, opacity:0, duration:.9, stagger:.12, ease:'power3.out', delay:.15});
    gsap.from('.stage', {scale:.85, opacity:0, duration:1.1, ease:'power3.out', delay:.3});
    gsap.from('.chip', {scale:0, opacity:0, duration:.6, stagger:.15, ease:'back.out(2)', delay:1});
    gsap.utils.toArray('.reveal').forEach((el: Element) => {
      gsap.to(el, {y:0, opacity:1, duration:.9, ease:'power3.out', scrollTrigger:{trigger:el, start:'top 86%'}});
    });
  } else {
    gsap.set('.reveal', {opacity:1, y:0});
  }

  gsap.utils.toArray('[data-count]').forEach((el: HTMLElement) => {
    const end = +el.dataset.count!, suf = el.dataset.suffix || '';
    ScrollTrigger.create({trigger:el, start:'top 88%', once:true, onEnter(){
      const o = {v:0};
      gsap.to(o, {v:end, duration:1.6, ease:'power2.out', onUpdate(){ el.textContent = Math.round(o.v)+suf; }});
      el.closest('.stat')?.classList.add('animate__animated','animate__pulse');
    }});
  });

  if (!reduced) {
    const steps = gsap.utils.toArray('.step') as HTMLElement[];
    const prog  = document.getElementById('prog') as HTMLElement | null;
    ScrollTrigger.create({
      trigger:'#engine', start:'top 64%', end:'+=1400', scrub:.6, pin:false,
      onUpdate(self: {progress:number}){
        const p = self.progress;
        if (prog) prog.style.width = (p*100)+'%';
        const active = Math.min(steps.length-1, Math.floor(p*steps.length+0.0001));
        steps.forEach((s,i) => s.classList.toggle('on', i <= active));
      }
    });
  }
}

/* ---------- animate.css on scroll ---------- */
/* Only observe elements not already handled by GSAP .reveal / step-engine */
if (!reduced) {
  const io = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting){ e.target.classList.add('animate__animated','animate__fadeInUp'); io.unobserve(e.target); }
    });
  }, {threshold:.2});
  document.querySelectorAll('.card,.quote').forEach(el => {
    if (!el.classList.contains('reveal')) io.observe(el);
  });
}

/* ---------- FAQ accordion ---------- */
document.querySelectorAll<HTMLButtonElement>('.q button').forEach(btn => {
  btn.addEventListener('click', () => {
    const q   = btn.parentElement!;
    const ans = q.querySelector<HTMLElement>('.ans')!;
    const open = q.classList.contains('open');
    document.querySelectorAll<HTMLElement>('.q').forEach(o => {
      o.classList.remove('open');
      const a = o.querySelector<HTMLElement>('.ans');
      if (a) a.style.maxHeight = '';
    });
    if (!open){ q.classList.add('open'); ans.style.maxHeight = ans.scrollHeight+'px'; }
  });
});
</script>
